{
  // ── Editor ──────────────────────────────────────────────────────────────
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.rulers": [120],
  "editor.wordWrap": "off",
  "editor.showFoldingControls": "always",
  "editor.folding": true,
  "editor.foldingStrategy": "indentation",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.renderWhitespace": "boundary",
  "editor.stickyScroll.enabled": true,
  "editor.minimap.enabled": true,
  "editor.minimap.renderCharacters": false,

  // ── C# (OmniSharp / Roslyn) ──────────────────────────────────────────────
"dotnet.defaultSolution": "DEEP6.csproj",
  "csharp.implementationsCodeLens.enabled": true,
  "csharp.format.enable": true,
  "omnisharp.enableEditorConfigSupport": true,
  "omnisharp.enableRoslynAnalyzers": true,
  "omnisharp.useModernNet": false,
  "omnisharp.sdkPath": "",

  // ── File associations ───────────────────────────────────────────────────
  "files.associations": {
    "*.cs":    "csharp",
    "*.csproj":"xml",
    "*.props": "xml",
    "*.targets":"xml",
    "*.ps1":   "powershell"
  },

  // ── Exclude noise from explorer ─────────────────────────────────────────
  "files.exclude": {
    "**/bin/**":  true,
    "**/obj/**":  true,
    "**/.git/**": true
  },

  // ── Search exclusions ──────────────────────────────────────────────────
  "search.exclude": {
    "**/bin": true,
    "**/obj": true
  },

  // ── Terminal ─────────────────────────────────────────────────────────────
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.cursorStyle": "line",

  // ── Explorer ─────────────────────────────────────────────────────────────
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.cs":    "${capture}.cs.meta",
    "*.csproj":"*.props,*.targets,*.sln"
  },
  "explorer.sortOrder": "type",

  // ── Git ──────────────────────────────────────────────────────────────────
  "git.autofetch": true,
  "git.enableSmartCommit": true,
  "git.confirmSync": false,

  // ── PowerShell ───────────────────────────────────────────────────────────
  "powershell.integratedConsole.showOnStartup": false,

  // ── Workbench ───────────────────────────────────────────────────────────
  "workbench.colorTheme": "One Dark Pro",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.startupEditor": "readme",
  "workbench.editor.highlightModifiedTabs": true,

  // ── NinjaTrader 8 path hints (update if NT8 is in a non-default location)
  "DEEP6.NT8InstallPath": "C:\\Program Files\\NinjaTrader 8",
"DEEP6.NT8CustomPath": "%USERPROFILE%\\Documents\\NinjaTrader 8\\bin\\Custom",
"dotnet.codeLens.enableReferencesCodeLens": true
}
