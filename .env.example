RITHMIC_USER=your_username
RITHMIC_PASSWORD=your_password
RITHMIC_SYSTEM_NAME=Rithmic Test
RITHMIC_URI=wss://rituz00100.rithmic.com:443
DEEP6_DB_PATH=./deep6_session.db

# DEEP6 API — FastAPI backend served by uvicorn.
# Unified on 8765 (dashboard + WS + REST). Change both server + dashboard in lockstep.
DEEP6_API_HOST=127.0.0.1
DEEP6_API_PORT=8765

# Dashboard (Next.js) base URL for the API. WebSocket URL is derived by swapping http→ws.
NEXT_PUBLIC_API_URL=http://localhost:8765

# Optional integrations
DATABENTO_API_KEY=
POLYGON_API_KEY=
